class STUDENT {
    String sname;
    double[] marks_array;
    double total;
    double avg;

    STUDENT() {
        this.sname = "empty";
        double[] empty = { -1, -1, -1 };
        this.marks_array = empty;
    }

    STUDENT(String sname, double[] marks_array) {
        this.sname = sname;
        this.marks_array = marks_array;
        compute();
    }

    void assign(String sname, double[] marks_array) {
        this.sname = sname;
        this.marks_array = marks_array;
        compute();
    }

    void display() {
        System.out.println("Name: " + this.sname);
        System.out.println("Total is: " + this.total);
        System.out.println("Avg is: " + this.avg);
        System.out.println("Marks are: ");
        for (double m : this.marks_array)
            System.out.print(m + " ");
        System.out.println();
    }

    void compute() {
        this.total = 0;
        for (double m : this.marks_array)
            this.total += m;

        this.avg = this.total / this.marks_array.length;
    }

    String extractInitials() {
        String init = "";
        String[] s_arr = sname.split(" ");
        init += s_arr[0].charAt(0);
        init += s_arr[1].charAt(0);
        return init;
    }

    void removeWhiteSpace() {
        char[] c_arr = sname.toCharArray();
        String out = "";
        for (char c : c_arr)
            if (!Character.isWhitespace(c))
                out += c;
        System.out.println(out);
    }
}

public class question_3 {
    public static void main(String[] args) {

        double[] marks = { 1, 2, 3, 45 };

        STUDENT st1 = new STUDENT("abhiraj singh", marks);
        STUDENT st2 = new STUDENT("Lewis Hamilton", marks);
        STUDENT st3 = new STUDENT("Fraud Vasseur", marks);

        STUDENT[] st_arr = { st1, st2, st3 };

        for (STUDENT s : st_arr) {
            if (s.sname.contains("singh"))
                System.out.println(s.sname);
        }

        System.out.println("In ascending order");

        for (int i = 0; i < 3; i++) {
            int min = i;
            for (int j = i; j < 3; j++)
                if (st_arr[j].sname.compareToIgnoreCase(st_arr[min].sname) < 0)
                    min = j;

            STUDENT temp = st_arr[i];
            st_arr[i] = st_arr[min];
            st_arr[min] = temp;
        }

        for (STUDENT s : st_arr)
            System.out.println(s.sname);

        System.out.println(st_arr[0].extractInitials());
        st_arr[0].removeWhiteSpace();
    }
}
