import java.util.Scanner;

class EMPLOYEE {
    String ename;
    String email;
    int eid;
    double basic;
    double gross_sal;
    double DA;
    double IT;
    double net_sal;
    Department[] departments;
    int max;
    int count = 0;

    EMPLOYEE() {
        this.ename = "empty";
        this.eid = -1;
        this.basic = -1;
    }

    EMPLOYEE(String ename, int eid, double basic, int m) {
        this.ename = ename;
        this.eid = eid;
        this.basic = basic;
        this.max = m;
        departments = new Department[m];
        compute_net_sal();
    }

    void formatEmployeeName() {
        String s_arr[] = ename.split(" ");
        String out = "";
        for (String m : s_arr) {
            if (m.isEmpty())
                continue;

            char[] c_arr = m.toCharArray();
            c_arr[0] = Character.toUpperCase(c_arr[0]);
            for (int i = 1; i < m.length(); i++)
                c_arr[i] = Character.toLowerCase(c_arr[i]);

            String word = new String(c_arr);
            out += word;
            out += " ";
        }
        ename = out.trim();
    }

    void generateEmail() {
        formatEmployeeName();
        String out = "";
        String[] s_arr = ename.split(" ");
        out += Character.toLowerCase(s_arr[0].charAt(0));
        out += s_arr[1].toLowerCase();
        email = out + "@example.com";
    }

    class Department {
        String departmentName;
        String location;

        Department(String dname, String loc) {
            departmentName = dname;
            location = loc;
        }

        void display() {
            System.out.println("Department name is:" + departmentName);
            System.out.println("Location is:" + location);
        }
    }

    void read(String ename, int eid, double basic) {
        this.ename = ename;
        this.eid = eid;
        this.basic = basic;
    }

    void display() {
        System.out.println("Name is: " + this.ename);
        System.out.println("EID is: " + this.eid);
        System.out.println("DA is : " + this.DA);
        System.out.println("IT paid is: " + this.IT);
        System.out.println("Net salary is: " + this.net_sal);
        for (int i = 0; i < count; i++)
            departments[i].display();
    }

    void compute_net_sal() {
        this.DA = 0.52 * this.basic;
        this.gross_sal = this.basic + this.DA;
        this.IT = 0.3 * this.gross_sal;
        this.net_sal = this.gross_sal - this.IT;
    }

    void addDepartment(String dname, String loc) {
        if (count < departments.length) {
            departments[count++] = new Department(dname, loc);
        } else
            System.out.println("max departments have been reach");
    }
}

public class question_2 {
    public static void main(String[] args) {

        EMPLOYEE emp1 = new EMPLOYEE("abhriaj singh", 1, 10000, 5);
        emp1.addDepartment("CSE", "AB5");
        emp1.addDepartment("ECE", "AB2");
        emp1.formatEmployeeName();
        emp1.generateEmail();

        System.out.println(emp1.ename);
        System.out.println(emp1.email);
    }
}
