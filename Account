class Account {
    String name;
    int accNo;
    String type;
    double balance;

    Account(String n, int a, String t, double b) {
        name = n;
        accNo = a;
        type = t;
        balance = b;
    }

    void deposit(double amt) {
        balance += amt;
    }

    void displayBalance() {
        System.out.println("Balance: " + balance);
    }

    void withdraw(double amt) {
        balance -= amt;
    }
}

class SavingsAccount extends Account {
    SavingsAccount(String n, int a, double b) {
        super(n, a, "Savings", b);
    }

    void addInterest() {
        balance += balance * 0.05;
    }
}

class CurrentAccount extends Account {
    double minBalance = 500;

    CurrentAccount(String n, int a, double b) {
        super(n, a, "Current", b);
    }

    void checkMinBalance() {
        if (balance < minBalance) {
            balance -= 50; // penalty
            System.out.println("Penalty imposed!");
        }
    }
}

public class TestAccount {
    public static void main(String[] args) {
        SavingsAccount s = new SavingsAccount("John", 101, 1000);
        CurrentAccount c = new CurrentAccount("Alice", 102, 400);

        s.deposit(500);
        s.addInterest();
        s.displayBalance();

        c.withdraw(100);
        c.checkMinBalance();
        c.displayBalance();
    }
}
